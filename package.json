{
  "name": "assertable",
  "version": "2.0.0",
  "description": "Tiny assertion helpers for runtime argument validation in Node.js, browsers, and mobile runtimes.",
  "main": "index.js",
  "module": "index.mjs",
  "browser": "dist/assertable.umd.js",
  "exports": {
    ".": {
      "require": "./index.js",
      "import": "./index.mjs",
      "default": "./index.js"
    },
    "./browser": "./dist/assertable.umd.js"
  },
  "files": [
    "index.js",
    "index.mjs",
    "dist",
    "LICENSE-MIT",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/splayfee/assertable.git"
  },
  "bugs": {
    "url": "https://github.com/splayfee/assertable/issues"
  },
  "docs": {
    "url": "https://github.com/splayfee/assertable/blob/master/LICENSE-MIT"
  },
  "license": "MIT",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "validator",
    "tool",
    "arguments",
    "method",
    "function",
    "test",
    "assert",
    "browser",
    "mobile"
  ],
  "homepage": "https://github.com/splayfee/assertable",
  "author": "David LaTour <david@edium.com>",
  "devDependencies": {
    "vitest": "^4.1.3"
  }
}
